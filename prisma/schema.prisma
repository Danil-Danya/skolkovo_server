generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EventRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum ReadNotificationStatus {
  UNREAD
  READ
}

enum UserStatus {
  BANNED
  WAITING
  ACTIVE
}

enum UserFollowStatus {
  FOLLOW
  UNFOLLOW
}


model users {
  id          String @id @default(uuid()) @map("id")

  tgChatId    String? @unique @map("tg_chat_id")
  tgUserName  String? @unique @map("tg_user_name")
  password    String
  status UserStatus @default(WAITING) @map("status")

  profile     profiles?
  news        news[]
  roles user_roles[]

  createdEvents events[] @relation("EventAuthor")
  eventRegistrations event_registrations[]
  followingRelations followers[] @relation("Follower")
  followerRelations  followers[] @relation("Following")

  readNotifications read_notifications[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
}

model profiles {
  id          String   @id @default(uuid()) @map("id")
  userId      String   @unique @map("user_id")

  companyLinks profile_companies[]

  positionId  String?  @map("position_id")
  position    positions? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  gender      String?  @map("gender")
  biography   String?  @map("biography")
  region      String?  @map("region")
  tgUser      String?  @map("tg_user")
  phone       String   @map("phone")
  education   String?  @map("education")
  avatarPath  String?  @map("avatar_path")

  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([positionId])
  @@map("profiles")
}

model roles {
  id          String  @id @default(uuid()) @map("id")
  name        String  @unique @map("name")

  userRoles   user_roles[]

  @@map("roles")
}

model user_roles {
  id        String @id @default(uuid()) @map("id")

  userId    String @map("user_id")
  roleId    String @map("role_id")

  user      users  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      roles  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model news {
  id           String @id @default(uuid()) @map("id")
  authorId     String? @map("author_id")          
  categoryId   String? @map("category_id")

  author       users?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category     news_categories? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  title        String @map("title")
  previewPath  String @map("preview_path")
  content      Json   @map("content")
  views        Int    @map("views")

  shortDescription String @map("short_description")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
}

model events {
  id           String @id @default(uuid()) @map("id")

  authorId     String? @map("author_id")  
  author       users?  @relation("EventAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  locationId   String @map("location_id")
  location     locations @relation(fields: [locationId], references: [id], onDelete: Restrict)

  registrations event_registrations[]

  title        String @map("title")
  previewPath  String? @map("preview_path")
  description  Json   @map("description")
  maxUnits     Int    @map("max_units")
  status       String @map("status")
  views        Int @map("views")

  price        Int?   @map("price")
  discount     Int?   @map("discount")

  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("events")
}

model event_registrations {
  id        String  @id @default(uuid()) @map("id")

  userId    String  @map("user_id")
  eventId   String  @map("event_id")

  status    EventRegistrationStatus @default(PENDING) @map("status")

  user      users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     events  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

model locations {
  id          String  @id @default(uuid()) @map("id")

  events      events[] 

  name        String @map("name")
  lat         String @map("lat")
  long        String @map("long")
  address     String @map("address")
  yandexLink  String @map("yandex_link")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model companies {
  id          String  @id @default(uuid()) @map("id")

  name        String @map("name")
  inn         String @map("inn")
  description String @map("description")
  phone       String @map("phone")
  site        String @map("site")
  previewPath String @map("preview_path")

  profileLinks profile_companies[]

  registeredAt DateTime? @map("registered_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyCategoryId String? @map("company_category_id")
  companyCategory   company_categories? @relation(fields: [companyCategoryId], references: [id], onDelete: SetNull)

  @@index([companyCategoryId])
  @@map("companies")
}

model company_categories {
  id          String  @id @default(uuid()) @map("id")
  name        String  @map("name")
  description String @map("description")

  companies    companies[]

  @@map("company_categories")
}

model profile_companies {
  profileId  String   @map("profile_id")
  companyId  String   @map("company_id")

  profile    profiles @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company    companies @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now()) @map("created_at")

  @@id([profileId, companyId])
  @@index([companyId])
  @@map("profile_companies")
}

model positions {
  id          String  @id @default(uuid()) @map("id")
  name        String  @map("name")
  description String @map("description")
  profiles    profiles[]

  @@map("positions")
}

model followers {
  id          String  @id @default(uuid()) @map("id")

  status      String  @map("status")

  followerId   String  @map("follower_id")
  followingId  String  @map("following_id")

  follower     users   @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following    users   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("followers")
}

model news_categories {
  id          String  @id @default(uuid()) @map("id")
  name        String  @map("name")

  news        news[]

  @@map("news_categories")
}

model notifications {
  id          String  @id @default(uuid()) @map("id")

  title       String @map("title")
  text        String @map("text")
  
  actionLinks Json?   @map("action_links")

  reads       read_notifications[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

model read_notifications {
  id              String  @id @default(uuid()) @map("id")

  userId          String  @map("user_id")
  notificationId  String  @map("notification_id")

  status          ReadNotificationStatus @default(UNREAD) @map("status")

  user            users @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification    notifications @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([notificationId])
  @@map("read_notifications")
}
